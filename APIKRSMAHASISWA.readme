    "academicPeriod": { "id_academic_period": 1, "name": "2024/2025 - Genap" },
    "setter": { "id_user_si": 5, "name": "Current Manager" }
  }
}
```

**Response Sukses — update (200)**:
```json
{
  "status": "success",
  "message": "Kuota KRS mahasiswa berhasil diperbarui.",
  "data": { "id_krs_quota": 1, "id_user_si": 100, "max_sks": 20, "notes": "Updated quota" }
}
