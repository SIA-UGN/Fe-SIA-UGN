            "lecturers": [{ "id_user_si": 20, "name": "Dr. William, M.Kom" }]
          }
        }
      ],
      "last_page": 3,
      "per_page": 20,
      "total": 45
    }
  }
}
```

> **Catatan**: Key paginasi ada di dalam `data.classes`, bukan `data` langsung.

---

### B6. POST /api/manager/krs-sessions/{id}/classes
**Deskripsi**: Tambah kelas ke dalam sesi KRS (batch).

**Path Params**:
| Param | Type    | Required | Keterangan     |
|-------|---------|----------|----------------|
| id    | integer | required | KRS session ID |

**Request Body**:
```json
{
  "classes": [
    { "id_class": 10 },
    { "id_class": 11 },
    { "id_class": 12 }
  ]
}
```

| Field              | Type    | Required | Keterangan             |
|--------------------|---------|----------|------------------------|
| classes            | array   | required | Min 1 item             |
| classes[].id_class | integer | required | ID kelas yang valid    |

**Response Sukses — ada kelas baru (201)**:
```json
{
  "status": "success",
  "message": "3 kelas berhasil ditambahkan ke sesi KRS.",
  "data": { "added": 3, "skipped": 0, "total_classes": 48 }
}
```

**Response Sukses — semua sudah ada (200)**:
```json
{
  "status": "success",
  "message": "Semua kelas yang diberikan sudah terdaftar dalam sesi ini.",
  "data": { "added": 0, "skipped": 3, "total_classes": 45 }
}
```

---

### B7. DELETE /api/manager/krs-sessions/{id}/classes/{class_id}
**Deskripsi**: Hapus kelas dari sesi KRS.

**Path Params**:
| Param    | Type    | Required | Keterangan         |
|----------|---------|----------|--------------------|
| id       | integer | required | KRS session ID     |
| class_id | integer | required | ID kelas yang dihapus |

**Response Sukses (200)**:
```json
{ "status": "success", "message": "Kelas berhasil dihapus dari sesi KRS." }
```

**Response Error (422)**:
```json
{ "status": "error", "message": "Kelas tidak ditemukan dalam sesi KRS ini." }
```

---

## C. Manajemen Kuota SKS Mahasiswa

Middleware: `auth:sanctum` + `role:admin|manager`
Base prefix: `/api/manager/krs-quotas`

---

### C1. GET /api/manager/krs-quotas
**Deskripsi**: Daftar kuota KRS seluruh mahasiswa dengan pagination.

**Query Params**:
| Param               | Type    | Required | Keterangan                  |
|---------------------|---------|----------|-----------------------------|
| id_academic_period  | integer | optional | Filter per periode akademik |
| search              | string  | optional | Cari nama/username mahasiswa|
| per_page            | integer | optional | Default: 15                 |
| page                | integer | optional | Default: 1                  |

**Response Sukses (200)**:
```json
{
  "status": "success",
  "message": "Daftar kuota KRS berhasil diambil.",
  "data": {
    "current_page": 1,
    "data": [
      {
        "id_krs_quota": 1,
        "id_user_si": 100,
        "id_academic_period": 1,
        "max_sks": 24,
        "notes": "Mahasiswa regular",
        "set_by": 5,
        "created_at": "2026-05-01T10:00:00.000000Z",
        "updated_at": "2026-05-01T10:00:00.000000Z",
        "student": { "id_user_si": 100, "name": "Wachyoudi", "username": "wachyoudi123" },
        "academicPeriod": { "id_academic_period": 1, "name": "Semester Ganjil 2024/2025", "is_active": true },
        "setter": { "id_user_si": 5, "name": "Manager User" }
      }
    ],
    "last_page": 2,
    "per_page": 15,
    "total": 28
  }
}
```

---

### C2. POST /api/manager/krs-quotas
**Deskripsi**: Tetapkan atau perbarui kuota SKS mahasiswa (upsert per mahasiswa per periode).

**Request Body**:
```json
{
  "id_user_si": 100,
  "id_academic_period": 1,
  "max_sks": 24,
  "notes": "Mahasiswa regular dengan IPK di atas 3.0"
}
```

| Field               | Type    | Required | Keterangan                                       |
|---------------------|---------|----------|--------------------------------------------------|
| id_user_si          | integer | required | User ID mahasiswa (role harus `mahasiswa`)       |
| id_academic_period  | integer | required | ID periode akademik yang valid                   |
| max_sks             | integer | required | Maks SKS, nilai 1–60                             |
| notes               | string  | optional | Catatan, maks 500 karakter                       |

**Response Sukses — kuota baru (201)**:
```json
{
  "status": "success",
  "message": "Kuota KRS mahasiswa berhasil ditetapkan.",
  "data": {
    "id_krs_quota": 1,
    "id_user_si": 100,
    "id_academic_period": 1,
    "max_sks": 24,
    "notes": "Mahasiswa regular dengan IPK di atas 3.0",
    "student": { "id_user_si": 100, "name": "Wachyoudi", "username": "wachyoudi123" },
    "academicPeriod": { "id_academic_period": 1, "name": "Semester Ganjil 2024/2025" },
    "setter": { "id_user_si": 5, "name": "Current Manager" }
  }
}
```

**Response Sukses — update (200)** (sama tapi `message`: `"...berhasil diperbarui."`)

**Response Error (422)**:
```json
{ "status": "error", "message": "Kuota KRS hanya dapat ditetapkan untuk pengguna dengan role mahasiswa." }
```

---

### C3. GET /api/manager/krs-quotas/{id}
**Deskripsi**: Detail kuota KRS mahasiswa beserta kalkulasi SKS yang terpakai.

**Path Params**:
| Param | Type    | Required | Keterangan   |
|-------|---------|----------|--------------|
| id    | integer | required | KRS quota ID |

**Response Sukses (200)**:
```json
{
  "status": "success",
  "message": "Detail kuota KRS berhasil diambil.",
  "data": {
    "id_krs_quota": 1,
    "id_user_si": 100,
    "id_academic_period": 1,
    "max_sks": 24,
    "notes": "Mahasiswa regular",
    "student": { "id_user_si": 100, "name": "Wachyoudi", "username": "wachyoudi123" },
    "academicPeriod": {
      "id_academic_period": 1,
      "name": "Semester Ganjil 2024/2025",
      "start_date": "2024-09-01",
      "end_date": "2025-01-31",
      "is_active": true
    },
    "setter": { "id_user_si": 5, "name": "Manager User" },
    "sks_used": 16,
    "sks_approved": 10,
    "sks_remaining": 8
  }
}
```

---

### C4. PATCH /api/manager/krs-quotas/{id}
**Deskripsi**: Update kuota SKS mahasiswa yang sudah ada.

**Path Params**:
| Param | Type    | Required | Keterangan   |
|-------|---------|----------|--------------|
| id    | integer | required | KRS quota ID |

**Request Body**:
```json
{ "max_sks": 20, "notes": "Updated karena performa akademik" }
```

| Field   | Type    | Required | Keterangan                       |
|---------|---------|----------|----------------------------------|
| max_sks | integer | optional | Nilai baru maks SKS (1–60)       |
| notes   | string  | optional | Catatan baru, maks 500 karakter  |

**Response Sukses (200)**:
```json
{
  "status": "success",
  "message": "Kuota KRS berhasil diperbarui.",
  "data": {
    "id_krs_quota": 1,
    "id_user_si": 100,
    "id_academic_period": 1,
    "max_sks": 20,
    "notes": "Updated karena performa akademik",
    "student": { "id_user_si": 100, "name": "Wachyoudi", "username": "wachyoudi123" },
    "academicPeriod": { "id_academic_period": 1, "name": "Semester Ganjil 2024/2025" },
    "setter": { "id_user_si": 5, "name": "Manager User" }
  }
}
```

---

### C5. DELETE /api/manager/krs-quotas/{id}
**Deskripsi**: Hapus kuota KRS mahasiswa.

**Path Params**:
| Param | Type    | Required | Keterangan   |
|-------|---------|----------|--------------|
| id    | integer | required | KRS quota ID |

**Response Sukses (200)**:
```json
{ "status": "success", "message": "Kuota KRS berhasil dihapus." }
```

