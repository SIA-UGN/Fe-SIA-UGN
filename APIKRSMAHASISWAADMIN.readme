    "sks_used": 16,
    "sks_approved": 5,
    "krs": [
      {
        "id_krs": 1,
        "id_krs_session": 1,
        "id_user_si": 100,
        "id_academic_period": 1,
        "id_class": 10,
        "id_subject": 1,
        "status": "pending",
        "rejection_reason": null,
        "processed_by": null,
        "processed_at": null,
        "created_at": "2026-05-15T10:30:00.000000Z",
        "subject": { "id_subject": 1, "name_subject": "Basis Data", "code_subject": "SVPL1234", "sks": 2 },
        "krsClass": {
          "id_class": 10,
          "code_class": "A",
          "day_of_week": "Senin",
          "start_time": "08:00:00",
          "end_time": "10:30:00",
          "subject": { "id_subject": 1, "name_subject": "Basis Data", "code_subject": "SVPL1234", "sks": 2 },
